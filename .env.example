# Vy Edge Control Environment Variables

# JWT Secret for session management
JWT_SECRET=vy-edge-secret-key-change-me

# Required: 64 hex characters (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=

# Initial Admin Password (will be hashed on first run)
ADMIN_PASSWORD=admin123

# Edge API Key (if you want a default one, though usually per-router)
# VITE_EDGE_DEFAULT_KEY=

# App URL (injected by AI Studio)
APP_URL=

# Set to true only for routers with self-signed certs (e.g., lab environments)
ALLOW_SELF_SIGNED=false

# Directory where backup files are temporarily written during download
BACKUP_DIR=./backups
