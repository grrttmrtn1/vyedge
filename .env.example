# Vy Edge Control Environment Variables

# JWT Secret for session management
JWT_SECRET=vy-edge-secret-key-change-me

# Initial Admin Password (will be hashed on first run)
ADMIN_PASSWORD=admin123

# Edge API Key (if you want a default one, though usually per-router)
# VITE_EDGE_DEFAULT_KEY=

# App URL (injected by AI Studio)
APP_URL=
